{
  "name": "cachekey",
  "version": "0.1.0",
  "description": "Local-first CI cache auditor for GitHub Actions workflows.",
  "type": "module",
  "bin": {
    "cachekey": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run test",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx",
    "smoke": "node scripts/smoke.mjs",
    "package:smoke": "npm run build && npm pack --dry-run",
    "release:check": "npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cache",
    "ci",
    "github-actions",
    "security",
    "typescript",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/cachekey.git"
  },
  "homepage": "https://github.com/rogerchappel/cachekey#readme",
  "bugs": {
    "url": "https://github.com/rogerchappel/cachekey/issues"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
